def set_status(doc: Doc, status: str) -> None:
    doc_type = doc.doc_type
    allowed = STATUS_BY_TYPE.get(doc_type, COMMON_STATUSES)
    if status not in allowed:
        raise SystemExit(f"Status {status!r} is not valid for {doc_type or doc.relpath}; choose one of: {', '.join(sorted(allowed))}")
    text = doc.path.read_text(encoding="utf-8")
    if not text.startswith("---\n"):
        raise SystemExit(f"{doc.relpath} has no frontmatter")
    end = text.find("\n---", 4)
    if end == -1:
        raise SystemExit(f"{doc.relpath} has malformed frontmatter")
    header = text[: end + 4]
    rest = text[end + 4 :]
    if re.search(r"^status:[^\n]*$", header, re.MULTILINE):
        header = re.sub(r"^status:[^\n]*$", f"status: {status}", header, flags=re.MULTILINE)
    else:
        header = header.replace("\n---", f"\nstatus: {status}\n---", 1)
    timestamp = now_string()
    if re.search(r"^updated_at:[^\n]*$", header, re.MULTILINE):
        header = re.sub(r"^updated_at:[^\n]*$", f'updated_at: "{timestamp}"', header, flags=re.MULTILINE)
    if "last_reviewed_commit:" in header:
        header = re.sub(r"^  last_reviewed_commit:[^\n]*$", f"  last_reviewed_commit: {git_head()}", header, flags=re.MULTILINE)
    doc.path.write_text(header + rest, encoding="utf-8")


CHECKBOX_RE = re.compile(r"(?m)^\s*[-*]\s+\[([ xX])\]\s+(.+)$")
TODO_TOKEN_RE = re.compile(r"^\[([^\]]+)\]\s*")


def parse_todo_body(body: str, checkbox_done: bool) -> tuple[str, str, dict[str, str], str]:
    todo_match = TODO_ID_START_RE.match(body)
    if not todo_match:
        return "", "done" if checkbox_done else "open", {}, body.strip()

    todo_id = f"TODO-{todo_match.group(1)}"
    rest = body[todo_match.end() :].strip()
    status = "done" if checkbox_done else "ready"
    metadata: dict[str, str] = {}

    while True:
        token_match = TODO_TOKEN_RE.match(rest)
        if not token_match:
            break
        token = token_match.group(1).strip()
        rest = rest[token_match.end() :].strip()
        if token in TODO_STATUSES and "status" not in metadata:
            status = token
            continue
        if ":" in token:
            key, value = token.split(":", 1)
            key = key.strip().lower().replace("-", "_")
            metadata[key] = value.strip()
            continue
        if "status" not in metadata:
            status = token
            metadata["status"] = token
            continue
        rest = f"[{token}] {rest}".strip()
        break

    return todo_id, status, metadata, rest.strip()


def todo_items_for_doc(doc: Doc, include_done: bool = False) -> list[TodoItem]:
    items: list[TodoItem] = []
    ignored_ranges = markdown_ignored_ranges(doc.content)
    source = doc.primary_id or doc.relpath

    for match in CHECKBOX_RE.finditer(doc.content):
        if in_ignored_markdown_range(match.start(), ignored_ranges):
            continue
        done = match.group(1).lower() == "x"
        todo_id, status, metadata, task = parse_todo_body(match.group(2).strip(), done)
        state = "done" if done else "open"
        if done and not include_done:
            continue
        item = TodoItem(
            state=state,
            line=line_number(doc.content, match.start()),
            task=task,
            source=source,
            path=doc.relpath,
            todo_id=todo_id,
            status=status,
            owner=metadata.get("owner", ""),
            agent=metadata.get("agent", ""),
            skill=metadata.get("skill", ""),
            plan=metadata.get("plan", ""),
            brief=metadata.get("brief", ""),
            metadata=metadata,
            structured=bool(todo_id),
            raw=match.group(0).strip(),
        )
        items.append(item)
    return items


def todo_items(docs: list[Doc], include_done: bool = False) -> list[TodoItem]:
    items: list[TodoItem] = []
    for doc in docs:
        items.extend(todo_items_for_doc(doc, include_done=include_done))
    return items


def task_rows(doc: Doc, include_done: bool = False) -> list[tuple[str, int, str, str]]:
    return [(item.state, item.line, item.task, item.source) for item in todo_items_for_doc(doc, include_done)]


def find_todo(items: list[TodoItem], todo_id: str) -> TodoItem | None:
    for item in items:
        if item.todo_id == todo_id:
            return item
    return None


def filter_todos(items: list[TodoItem], args: argparse.Namespace) -> list[TodoItem]:
    selected = items
    if getattr(args, "id", None) and str(args.id).startswith("TODO-"):
        selected = [item for item in selected if item.todo_id == args.id]
    if getattr(args, "status", None):
        selected = [item for item in selected if item.status == args.status]
    if getattr(args, "owner", None):
        selected = [item for item in selected if item.owner == args.owner]
    if getattr(args, "agent", None):
        selected = [item for item in selected if item.agent == args.agent]
    if getattr(args, "skill", None):
        selected = [item for item in selected if item.skill == args.skill]
    if getattr(args, "plan", None):
        selected = [item for item in selected if item.plan == args.plan]
    if getattr(args, "brief", None):
        selected = [item for item in selected if item.brief == args.brief]
    if getattr(args, "structured_only", False):
        selected = [item for item in selected if item.structured]
    return selected


def format_todo_rows(items: list[TodoItem]) -> str:
    if not items:
        return "No todos found."
    rows = []
    for item in items:
        if item.structured:
            rows.append(
                "\t".join(
                    [
                        item.status,
                        item.todo_id,
                        item.owner,
                        item.agent,
                        item.skill,
                        item.source,
                        f"{item.path}:{item.line}",
                        item.task,
                    ]
                )
            )
        else:
            rows.append(f"{item.state}\t{item.source}\t{item.path}:{item.line}\t{item.task}")
    return "\n".join(rows)


def markdown_table_cell(value: object) -> str:
    text = str(value) if value is not None else ""
    return text.replace("\\", "\\\\").replace("|", "\\|").replace("\n", " ")


def field_summary(value: object) -> str:
    if isinstance(value, list):
        return ", ".join(str(item) for item in value)
    if isinstance(value, dict):
        pieces = []
        for key in ("type", "link", "notes"):
            item = value.get(key)
            if item:
                pieces.append(str(item))
        return " / ".join(pieces)
    return str(value) if value else ""


def generated_view(doc_type: str, title: str, body_lines: list[str], timestamp: str | None = None) -> str:
    updated_at = timestamp or now_string()
    lines = [
        "---",
        f"type: {doc_type}",
        f"title: {title}",
        "status: generated",
        f'updated_at: "{updated_at}"',
        "---",
        "",
    ]
    lines.extend(body_lines)
    return "\n".join(lines)


def normalize_generated_view(text: str) -> str:
    return re.sub(r'^updated_at: ".*"$', 'updated_at: "<generated>"', text, flags=re.MULTILINE)


def ideas_markdown(docs: list[Doc]) -> str:
    ideas = sorted((doc for doc in docs if doc.primary_id.startswith("IDEA-")), key=lambda d: d.primary_id)
    lines = [
        "# Idea Registry",
        "",
        GENERATED_HEADER,
        "",
        "Global registry for lightweight ideas. Ideas are captured sparks, not approved specs.",
        "",
        "| ID | Title | Domain | Status | Path | Source | Promoted To |",
        "|---|---|---|---|---|---|---|",
    ]
    for doc in ideas:
        lines.append(
            "| {id} | {title} | {domain} | {status} | `{path}` | {source} | {promoted_to} |".format(
                id=doc.primary_id,
                title=doc.title,
                domain=doc.frontmatter.get("domain", ""),
                status=doc.status,
                path=doc.relpath,
                source=field_summary(doc.frontmatter.get("source", "")),
                promoted_to=field_summary(doc.frontmatter.get("promoted_to", "")),
            )
        )
    lines.append("")
    return generated_view("generated-view", "Idea Registry", lines)


def concepts_markdown(docs: list[Doc]) -> str:
    concepts = sorted((doc for doc in docs if doc.primary_id.startswith("CONC-")), key=lambda d: d.primary_id)
    lines = [
        "# Concept Registry",
        "",
        GENERATED_HEADER,
        "",
        "Global registry for semi-mature concept notes. Concepts incubate domain models, taxonomy, ontology, and naming before they become specs, ADRs, plans, or explainers.",
        "",
        "| ID | Title | Type | Domain | Status | Path | Promoted To |",
        "|---|---|---|---|---|---|---|",
    ]
    for doc in concepts:
        lines.append(
            "| {id} | {title} | {typ} | {domain} | {status} | `{path}` | {promoted_to} |".format(
                id=markdown_table_cell(doc.primary_id),
                title=markdown_table_cell(doc.title),
                typ=markdown_table_cell(doc.frontmatter.get("concept_type", "")),
                domain=markdown_table_cell(doc.frontmatter.get("domain", "")),
                status=markdown_table_cell(doc.status),
                path=markdown_table_cell(doc.relpath),
                promoted_to=markdown_table_cell(field_summary(doc.frontmatter.get("promoted_to", ""))),
            )
        )
    if not concepts:
        lines.append("|  |  |  |  |  | No concept notes found. |  |")
    lines.append("")
    return generated_view("generated-view", "Concept Registry", lines)


