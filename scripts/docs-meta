    return generated_view("generated-view", "Explainer Registry", lines)


def questions_markdown(docs: list[Doc]) -> str:
    questions = sorted((doc for doc in docs if doc.primary_id.startswith("QST-")), key=lambda d: d.primary_id)
    lines = [
        "# Question Registry",
        "",
        GENERATED_HEADER,
        "",
        "Global registry for durable open questions. Questions track uncertainty that needs resolution, evidence, or ownership.",
        "",
        "| ID | Title | Type | Domain | Status | Owner | Needed By | Resolved By | Path |",
        "|---|---|---|---|---|---|---|---|---|",
    ]
    for doc in questions:
        lines.append(
            "| {id} | {title} | {typ} | {domain} | {status} | {owner} | {needed_by} | {resolved_by} | `{path}` |".format(
                id=markdown_table_cell(doc.primary_id),
                title=markdown_table_cell(doc.title),
                typ=markdown_table_cell(doc.frontmatter.get("question_type", "")),
                domain=markdown_table_cell(doc.frontmatter.get("domain", "")),
                status=markdown_table_cell(doc.status),
                owner=markdown_table_cell(doc.frontmatter.get("owner", "")),
                needed_by=markdown_table_cell(doc.frontmatter.get("decision_needed_by", "")),
                resolved_by=markdown_table_cell(field_summary(doc.frontmatter.get("resolved_by", ""))),
                path=markdown_table_cell(doc.relpath),
            )
        )
    if not questions:
        lines.append("|  |  |  |  |  |  |  |  | No questions found. |")
    lines.append("")
    return generated_view("generated-view", "Question Registry", lines)


def registry_markdown(docs: list[Doc]) -> str:
    tracked = sorted((doc for doc in docs if doc.primary_id), key=lambda d: d.primary_id)
    lines = [
        "# Docs Registry",
        "",
        GENERATED_HEADER,
        "",
        "| ID | Type | Title | Status | Path |",
        "|---|---|---|---|---|",
    ]
    for doc in tracked:
        lines.append(f"| {doc.primary_id} | {doc.doc_type} | {doc.title} | {doc.status} | `{doc.relpath}` |")
    lines.append("")
    return generated_view("generated-view", "Docs Registry", lines)


def todos_markdown(docs: list[Doc]) -> str:
    items = todo_items(docs)
    structured = [item for item in items if item.structured]
    local = [item for item in items if not item.structured]
    lines = [
        "# Docs Todos",
        "",
        GENERATED_HEADER,
        "",
        "Generated dashboard for Markdown todos. Source docs are canonical; edit the source checkbox line, then regenerate this view.",
        "",
        "## Structured Todos",
        "",
    ]
    if structured:
        lines.extend(
            [
                "| ID | Status | Owner | Agent | Updated | Skill | Source | Path | Line | Plan | Brief | Task |",
                "|---|---|---|---|---|---|---|---|---:|---|---|---|",
            ]
        )
        for item in structured:
            lines.append(
                "| {id} | {status} | {owner} | {agent} | {updated} | {skill} | {source} | {path} | {line} | {plan} | {brief} | {task} |".format(
                    id=markdown_table_cell(item.todo_id),
                    status=markdown_table_cell(item.status),
                    owner=markdown_table_cell(item.owner),
                    agent=markdown_table_cell(item.agent),
                    updated=markdown_table_cell(item.metadata.get("updated", "")),
                    skill=markdown_table_cell(item.skill),
                    source=markdown_table_cell(item.source),
                    path=markdown_table_cell(f"`{item.path}`"),
                    line=item.line,
                    plan=markdown_table_cell(item.plan),
                    brief=markdown_table_cell(item.brief),
                    task=markdown_table_cell(item.task),
                )
            )
    else:
        lines.append("No structured `TODO-*` items found.")
    lines.extend(
        [
            "",
            "## Local Checkboxes",
            "",
        ]
    )
    if local:
        lines.extend(
            [
                "| State | Source | Line | Task |",
                "|---|---|---:|---|",
            ]
        )
        for item in local:
            lines.append(
                "| {state} | {source} | {line} | {task} |".format(
                    state=markdown_table_cell(item.state),
                    source=markdown_table_cell(item.source),
                    line=item.line,
                    task=markdown_table_cell(item.task),
                )
            )
    else:
        lines.append("No local checkbox todos found.")
    lines.append("")
    return generated_view("generated-view", "Docs Todos", lines)


def areas_markdown(docs: list[Doc]) -> str:
    areas = sorted((doc for doc in docs if doc.doc_type == "architecture-area"), key=lambda d: d.primary_id or d.title)
    lines = [
        "# Architecture Area Registry",
        "",
        GENERATED_HEADER,
        "",
        "| ID | Title | Status | Path |",
        "|---|---|---|---|",
    ]
    for doc in areas:
        lines.append(f"| {doc.primary_id} | {doc.title} | {doc.status} | `{doc.relpath}` |")
    lines.append("")
    return generated_view("generated-view", "Architecture Area Registry", lines)


def audit_docs(docs: list[Doc]) -> list[Doc]:
    return sorted((doc for doc in docs if doc.doc_type == "repo-health-audit"), key=lambda d: d.frontmatter.get("audit_ended_at") or d.frontmatter.get("created_at") or d.relpath, reverse=True)


def audits_markdown(docs: list[Doc]) -> str:
    audits = audit_docs(docs)
    lines = [
        "# Repo Health Audits",
        "",
        GENERATED_HEADER,
        "",
        "Generated index of repo-health audits. Audits are periodic receipts for docs, architecture, maintenance, duplication/refactor, tests, tooling, and other project hygiene checks.",
        "",
        "| Date | Status | Title | Scope | Path |",
        "|---|---|---|---|---|",
    ]
    for doc in audits:
        ended_at = doc.frontmatter.get("audit_ended_at") or doc.frontmatter.get("created_at", "")
        date = str(ended_at).split(" ", 1)[0] if ended_at else ""
        lines.append(f"| {date} | {doc.status} | {doc.title} | {field_summary(doc.frontmatter.get('scope', ''))} | `{doc.relpath}` |")
    lines.append("")
    return generated_view("generated-view", "Repo Health Audits", lines)


def sequence_value(doc: Doc) -> str:
    sequence = doc.frontmatter.get("sequence")
    if isinstance(sequence, dict):
        value = sequence.get("roadmap") or sequence.get("sort_key")
        return str(value) if value else ""
    value = doc.frontmatter.get("roadmap_sequence")
    return str(value) if value else ""


def sort_sequence(value: str) -> tuple:
    if not value:
        return ((1, "zzzzzz"),)
    parts: list[tuple[int, object]] = []
    for part in re.split(r"([0-9]+)", value):
        if part == "":
            continue
        if part.isdigit():
            parts.append((0, int(part)))
        else:
            parts.append((1, part.lower()))
    return tuple(parts)


def roadmap_rows(docs: list[Doc]) -> list[dict[str, str]]:
    plans = sorted((doc for doc in docs if doc.doc_type == "plan"), key=lambda d: (sort_sequence(sequence_value(d)), d.primary_id))
    rows: list[dict[str, str]] = []
    for doc in plans:
        sequence = doc.frontmatter.get("sequence")
        after = before = lane = ""
        if isinstance(sequence, dict):
            after = field_summary(sequence.get("after", ""))
            before = field_summary(sequence.get("before", ""))
            lane = str(sequence.get("lane", "") or "")
        plan_name = doc.path.stem
        rows.append(
            {
                "sequence": sequence_value(doc),
                "id": doc.primary_id,
                "plan_name": plan_name,
                "title": doc.title,
                "status": doc.status,
                "domain": str(doc.frontmatter.get("domain", "")),
                "lane": lane,
                "after": after,
                "before": before,
                "path": doc.relpath,
            }
        )
    return rows


def roadmap_markdown(docs: list[Doc]) -> str:
    rows = roadmap_rows(docs)
    lines = [
        "# Roadmap View",
        "",
        GENERATED_HEADER,
        "",
        "Generated plan-order view. `PLAN-*` IDs are stable identity; `sequence` frontmatter owns execution order.",
        "",
        "| Sequence | Plan | Plan Name | Title | Status | Domain | Lane | After | Before | Path |",
        "|---|---|---|---|---|---|---|---|---|---|",
    ]
    for row in rows:
        lines.append(
            "| {sequence} | {id} | {plan_name} | {title} | {status} | {domain} | {lane} | {after} | {before} | `{path}` |".format(**row)
        )
    if not rows:
        lines.append("|  |  |  | No plans found. |  |  |  |  |  |  |")
    lines.append("")
    return generated_view("generated-view", "Roadmap View", lines)


def parse_timestamp(value: object) -> dt.datetime | None:
    if not isinstance(value, str) or not value:
        return None
    match = re.search(r"(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})(?: [A-Za-z0-9_+/-]+)? ([+-]\d{4})", value)
    if match:
        try:
            return dt.datetime.strptime(f"{match.group(1)} {match.group(2)}", "%Y-%m-%d %H:%M:%S %z")
        except ValueError:
            return None
    try:
        parsed = dt.datetime.fromisoformat(value)
        if parsed.tzinfo is None:
            parsed = parsed.replace(tzinfo=dt.datetime.now().astimezone().tzinfo)
        return parsed
    except ValueError:
        return None


def nested_value(mapping: dict[str, object], key: str, child_key: str) -> str:
    value = mapping.get(key)
    if isinstance(value, dict):
        child = value.get(child_key)
        return child if isinstance(child, str) else ""
    return ""


def health_issues(root: Path, docs: list[Doc], stale_days: int, commit_threshold: int, audit_days: int) -> list[HealthIssue]:
    issues: list[HealthIssue] = []
    now = dt.datetime.now().astimezone()
    current_head = git_head()
    freshness_types = {
        "current-state",
        "onboarding",
        "roadmap",
        "architecture-overview",
        "architecture-area",
        "codebase-map",
        "data-seams",
        "testing-guide",
    }
    work_statuses = {"captured", "exploring", "draft", "proposed", "ready", "in_progress", "in-progress", "blocked"}
    archived_statuses = {"archived", "rejected", "superseded"}
    audits = audit_docs(docs)
    completed_audits = [doc for doc in audits if doc.status == "completed"]
    if not completed_audits:
        issues.append(
            HealthIssue(
                "info",
                "missing-repo-health-audit",
                "repo-health/audits/",
                "No completed repo-health audit found.",
                "Create one after periodic docs, architecture, maintenance, tests, and tooling checks.",
            )
        )
    else:
        last_audit = completed_audits[0]
        audit_time = parse_timestamp(last_audit.frontmatter.get("audit_ended_at") or last_audit.frontmatter.get("updated_at"))
        if audit_time:
            audit_age = (now - audit_time).days
            if audit_age >= audit_days:
                issues.append(
                    HealthIssue(
                        "warn",
                        "repo-health-audit-due",
                        last_audit.relpath,
                        f"Last completed repo-health audit was {audit_age} days ago.",
                        f"Threshold: {audit_days} days",
                    )
                )

    for doc in docs:
        doc_type = doc.doc_type
        if not doc_type or doc.status in archived_statuses:
            continue

        updated_at = parse_timestamp(doc.frontmatter.get("updated_at"))
        age_days = (now - updated_at).days if updated_at else None
        label = doc.primary_id or doc.relpath

        if doc_type in freshness_types:
            if age_days is None:
                issues.append(HealthIssue("warn", "missing-updated-at", doc.relpath, f"{label} has no parseable updated_at timestamp."))
            elif age_days >= stale_days:
                issues.append(
                    HealthIssue(
                        "warn",
                        "stale-by-time",
                        doc.relpath,
                        f"{label} has not been updated in {age_days} days.",
                        f"Threshold: {stale_days} days",
                    )
                )

        if doc.status in work_statuses and age_days is not None and age_days >= stale_days:
            severity = "warn" if doc.status == "blocked" else "info"
            issues.append(
                HealthIssue(
                    severity,
                    "open-work-aging",
                    doc.relpath,
                    f"{label} is {doc.status} and has not been updated in {age_days} days.",
                    f"Review whether the status still reflects reality.",
                )
            )

        reviewed_commit = nested_value(doc.frontmatter, "repo_state", "last_reviewed_commit")
        if "repo_state" in doc.frontmatter and not reviewed_commit:
            issues.append(HealthIssue("info", "missing-review-commit", doc.relpath, f"{label} has repo_state but no last_reviewed_commit."))
        elif reviewed_commit and current_head and reviewed_commit != current_head:
            count = git_commit_count_since(reviewed_commit)
            if count is not None and count >= commit_threshold:
                issues.append(
                    HealthIssue(
                        "warn",
                        "stale-by-commit",
                        doc.relpath,
                        f"{label} was last reviewed {count} commits ago.",
                        f"last_reviewed_commit: {reviewed_commit}",
                    )
                )

    refs = link_graph(root, docs)
    for ref in broken_link_refs(refs):
        issues.append(
            HealthIssue(
                "warn",
                "broken-link",
                ref.source_rel,
                f"{ref.source_rel}:{ref.line} links to {ref.href!r}, which is {ref.status}.",
                ref.detail,
            )
        )
    for ref in refs:
        if ref.status in {"absolute-repo-local", "root-relative"}:
            issues.append(
                HealthIssue(
                    "info",
                    "non-relative-link",
                    ref.source_rel,
                    f"{ref.source_rel}:{ref.line} uses a {ref.status} repo-local href.",
                    ref.href,
                )
            )
    for doc in orphan_docs(root, docs, refs):
        issues.append(
            HealthIssue(
                "info",
                "orphan-doc",
                doc.relpath,
                f"{doc.primary_id or doc.relpath} has no inbound Markdown links.",
                "Review whether this is intentional or add an index/backlink.",
            )
        )

    return issues


def health_markdown(issues: list[HealthIssue], stale_days: int, commit_threshold: int, audit_days: int) -> str:
    lines = [
        "# Docs Health",
        "",
        GENERATED_HEADER,
        "",
        "Advisory review queue for docs that may be stale or worth checking. This is not a correctness report; use `scripts/docs-meta check` for deterministic validation.",
        "",
        f"- Time threshold: {stale_days} days",
        f"- Commit threshold: {commit_threshold} commits since `repo_state.last_reviewed_commit`",
        f"- Audit threshold: {audit_days} days since last completed repo-health audit",
        "",
        "| Severity | Code | Doc | Message | Detail |",
        "|---|---|---|---|---|",
    ]
    for issue in issues:
        lines.append(f"| {issue.severity} | {issue.code} | `{issue.doc}` | {issue.message} | {issue.detail} |")
    if not issues:
        lines.append("| ok | none |  | No docs health issues found. |  |")
    lines.append("")
    return generated_view("generated-view", "Docs Health", lines)


def health_text(issues: list[HealthIssue]) -> str:
    if not issues:
        return "No docs health issues found."
    return "\n".join(
        f"{issue.severity.upper()}\t{issue.code}\t{issue.doc}\t{issue.message}" + (f"\t{issue.detail}" if issue.detail else "")
        for issue in issues
    )


def generated_view_path(root: Path, name: str) -> Path:
    paths = {
        "ideas": root / "IDEAS.md",
        "concepts": root / "CONCEPTS.md",
        "specs": root / "SPECS.md",
        "learnings": root / "LEARNINGS.md",
        "explainers": root / "EXPLAINERS.md",
        "questions": root / "QUESTIONS.md",
        "registry": root / "DOCS-REGISTRY.md",
        "todos": root / "TODOS.md",
        "areas": root / "AREAS.md",
        "audits": root / "AUDITS.md",
        "roadmap": root / "ROADMAP-VIEW.md",
        "health": root / "HEALTH.md",
    }
    return paths[name]


def generated_view_markdown(root: Path, name: str, docs: list[Doc], args: argparse.Namespace | None = None) -> str:
    if name == "ideas":
        return ideas_markdown(docs)
    if name == "concepts":
        return concepts_markdown(docs)
    if name == "specs":
        return specs_markdown(docs)
    if name == "learnings":
        return learnings_markdown(docs)
    if name == "explainers":
        return explainers_markdown(docs)
    if name == "questions":
        return questions_markdown(docs)
    if name == "registry":
        return registry_markdown(docs)
    if name == "todos":
        return todos_markdown(docs)
    if name == "areas":
        return areas_markdown(docs)
    if name == "audits":
        return audits_markdown(docs)
    if name == "roadmap":
        return roadmap_markdown(docs)
    if name == "health":
        stale_days = getattr(args, "stale_days", 14)
        commit_threshold = getattr(args, "commit_threshold", 10)
        audit_days = getattr(args, "audit_days", 30)
        issues = health_issues(root, docs, stale_days, commit_threshold, audit_days)
        return health_markdown(issues, stale_days, commit_threshold, audit_days)
    raise SystemExit(f"Unknown generated view: {name}")


def write_generated_view(root: Path, name: str, docs: list[Doc], args: argparse.Namespace | None = None) -> str:
    markdown = generated_view_markdown(root, name, docs, args)
    generated_view_path(root, name).write_text(markdown, encoding="utf-8")
    return markdown


def update(root: Path, docs: list[Doc]) -> None:
    if any(doc.primary_id.startswith("IDEA-") for doc in docs) or (root / "IDEAS.md").exists():
        write_generated_view(root, "ideas", docs)
    if any(doc.primary_id.startswith("CONC-") for doc in docs) or (root / "CONCEPTS.md").exists():
        write_generated_view(root, "concepts", docs)
    if any(doc.primary_id.startswith("LRN-") for doc in docs) or (root / "LEARNINGS.md").exists():
        write_generated_view(root, "learnings", docs)
    if any(doc.primary_id.startswith("EXPL-") for doc in docs) or (root / "EXPLAINERS.md").exists():
        write_generated_view(root, "explainers", docs)
    if any(doc.primary_id.startswith("QST-") for doc in docs) or (root / "QUESTIONS.md").exists():
        write_generated_view(root, "questions", docs)
    write_generated_view(root, "specs", docs)
    write_generated_view(root, "registry", docs)
    write_generated_view(root, "todos", docs)
    if any(doc.doc_type == "repo-health-audit" for doc in docs) or (root / "AUDITS.md").exists():
        write_generated_view(root, "audits", docs)
    if any(doc.doc_type == "plan" for doc in docs) or (root / "ROADMAP-VIEW.md").exists():
        write_generated_view(root, "roadmap", docs)
    if any(doc.doc_type == "architecture-area" for doc in docs) or (root / "AREAS.md").exists():
        write_generated_view(root, "areas", docs)


def check(root: Path, docs: list[Doc]) -> int:
    errors: list[str] = []
    seen: dict[str, str] = {}
    for doc in docs:
        doc_id = doc.primary_id
        if not doc_id:
            if doc.doc_type in {"research-survey", "evaluation", "diagnostic-record"}:
                errors.extend(validate_frontmatter(doc))
            continue
        if doc_id in seen:
            errors.append(f"Duplicate ID {doc_id}: {seen[doc_id]} and {doc.relpath}")
        seen[doc_id] = doc.relpath
        if doc_id not in doc.path.name:
            errors.append(f"ID {doc_id} is not present in filename: {doc.relpath}")
        errors.extend(validate_frontmatter(doc))
        errors.extend(validate_linked_paths(doc, root))

    generated = {
        root / "SPECS.md": specs_markdown(docs),
        root / "DOCS-REGISTRY.md": registry_markdown(docs),
        root / "TODOS.md": todos_markdown(docs),
    }
    if any(doc.primary_id.startswith("IDEA-") for doc in docs) or (root / "IDEAS.md").exists():
        generated[root / "IDEAS.md"] = ideas_markdown(docs)
    if any(doc.primary_id.startswith("CONC-") for doc in docs) or (root / "CONCEPTS.md").exists():
        generated[root / "CONCEPTS.md"] = concepts_markdown(docs)
    if any(doc.primary_id.startswith("LRN-") for doc in docs) or (root / "LEARNINGS.md").exists():
        generated[root / "LEARNINGS.md"] = learnings_markdown(docs)
    if any(doc.primary_id.startswith("EXPL-") for doc in docs) or (root / "EXPLAINERS.md").exists():
        generated[root / "EXPLAINERS.md"] = explainers_markdown(docs)
    if any(doc.primary_id.startswith("QST-") for doc in docs) or (root / "QUESTIONS.md").exists():
        generated[root / "QUESTIONS.md"] = questions_markdown(docs)
    if any(doc.doc_type == "repo-health-audit" for doc in docs) or (root / "AUDITS.md").exists():
        generated[root / "AUDITS.md"] = audits_markdown(docs)
    if any(doc.doc_type == "plan" for doc in docs) or (root / "ROADMAP-VIEW.md").exists():
        generated[root / "ROADMAP-VIEW.md"] = roadmap_markdown(docs)
    if any(doc.doc_type == "architecture-area" for doc in docs) or (root / "AREAS.md").exists():
        generated[root / "AREAS.md"] = areas_markdown(docs)
    for path, expected in generated.items():
        if path.exists() and normalize_generated_view(path.read_text(encoding="utf-8")) != normalize_generated_view(expected):
            errors.append(f"Generated file is stale: {path.relative_to(root)}")

    for error in errors:
        print(f"ERROR: {error}", file=sys.stderr)
    return 1 if errors else 0


def todo_validation_issues(docs: list[Doc], strict: bool = False) -> tuple[list[str], list[str]]:
    errors: list[str] = []
    warnings: list[str] = []
    items = todo_items(docs, include_done=True)
    structured = [item for item in items if item.structured]
    by_id: dict[str, TodoItem] = {}
    doc_ids = {doc.primary_id for doc in docs if doc.primary_id}

    for item in structured:
        where = f"{item.path}:{item.line}"
        if item.todo_id in by_id:
            previous = by_id[item.todo_id]
            errors.append(f"Duplicate todo ID {item.todo_id}: {previous.path}:{previous.line} and {where}")
        else:
            by_id[item.todo_id] = item
        if item.status not in TODO_STATUSES:
            errors.append(f"{where} has invalid todo status {item.status!r} for {item.todo_id}")
        if item.state == "done" and item.status in TODO_ACTIVE_STATUSES:
            errors.append(f"{where} has checked checkbox but active status {item.status!r} for {item.todo_id}")
        if item.state == "open" and item.status == "done":
            errors.append(f"{where} has open checkbox but done status for {item.todo_id}")
        if item.status == "in_progress":
            if not item.owner:
                errors.append(f"{where} has in_progress status without owner for {item.todo_id}")
            if not item.agent:
                errors.append(f"{where} has in_progress status without agent for {item.todo_id}")
            if not item.metadata.get("updated"):
                errors.append(f"{where} has in_progress status without updated timestamp for {item.todo_id}")
        if item.status == "review" and not item.metadata.get("updated"):
            errors.append(f"{where} has review status without updated timestamp for {item.todo_id}")
        if item.status == "blocked" and not any(item.metadata.get(key) for key in ("blocker", "blocked_by", "reason")):
            errors.append(f"{where} has blocked status without blocker, blocked_by, or reason for {item.todo_id}")
        if item.status == "done" and not any(item.metadata.get(key) for key in ("verification", "evidence", "reason")):
            errors.append(f"{where} has done status without verification, evidence, or reason for {item.todo_id}")
        if item.status == "superseded" and not any(item.metadata.get(key) for key in ("replacement", "reason")):
            errors.append(f"{where} has superseded status without replacement or reason for {item.todo_id}")
        if item.status == "archived" and not item.metadata.get("reason"):
            errors.append(f"{where} has archived status without reason for {item.todo_id}")
        if item.plan and item.plan not in doc_ids:
            errors.append(f"{where} references missing plan {item.plan} for {item.todo_id}")
        if item.brief and item.brief not in doc_ids:
            errors.append(f"{where} references missing brief {item.brief} for {item.todo_id}")
        for key in ("depends", "depends_on", "blocker", "blocked_by", "blocks"):
            value = item.metadata.get(key, "")
            if not value or not value.startswith("TODO-"):
                continue
            for ref_id in re.split(r"[, ]+", value):
                ref_id = ref_id.strip()
                if ref_id.startswith("TODO-") and ref_id not in by_id and not find_todo(structured, ref_id):
                    errors.append(f"{where} references missing todo {ref_id} in {key} for {item.todo_id}")
        if strict and not item.skill:
            warnings.append(f"{where} has no skill metadata for {item.todo_id}")
        if strict and item.status in {"blocked", "ready"} and not item.metadata.get("updated"):
            warnings.append(f"{where} has no updated metadata for {item.todo_id}")

    return errors, warnings


def check_todos(docs: list[Doc], use_json: bool = False, strict: bool = False) -> int:
    errors, warnings = todo_validation_issues(docs, strict=strict)
    payload = {"errors": errors, "warnings": warnings}
    if use_json:
        print(json.dumps(payload, indent=2))
    else:
        for warning in warnings:
            print(f"WARN: {warning}", file=sys.stderr)
        for error in errors:
            print(f"ERROR: {error}", file=sys.stderr)
        if not errors and not warnings:
            print("No todo issues found.")
    return 1 if errors else 0


def validate_frontmatter(doc: Doc) -> list[str]:
    errors: list[str] = []
    doc_type = doc.doc_type
    if not doc_type:
        return errors
    if doc_type not in KNOWN_DOC_TYPES:
        errors.append(f"Unknown frontmatter type {doc_type!r} in {doc.relpath}")
        return errors

    required = REQUIRED_FIELDS_BY_TYPE.get(doc_type, set())
    missing = sorted(field for field in required if field not in doc.frontmatter)
    for field in missing:
        errors.append(f"Missing frontmatter field {field!r} in {doc.relpath}")

    allowed_statuses = STATUS_BY_TYPE.get(doc_type, COMMON_STATUSES)
    if doc.status and doc.status not in allowed_statuses:
        errors.append(f"Unknown status {doc.status!r} for type {doc_type!r} in {doc.relpath}")

    if doc_type == "architecture-area":
        doc_id = doc.primary_id
        if doc_id and doc.path.stem != doc_id:
            errors.append(f"Architecture area ID {doc_id} must match filename stem in {doc.relpath}")

    frontmatter_id = doc.frontmatter.get("id")
    if isinstance(frontmatter_id, str) and frontmatter_id:
        filename_ids = set(find_ids(doc.path.name))
        family = frontmatter_id.split("-", 1)[0]
        mismatches = sorted(doc_id for doc_id in filename_ids if doc_id.startswith(f"{family}-") and doc_id != frontmatter_id)
        for mismatch in mismatches:
            errors.append(f"Frontmatter ID {frontmatter_id} conflicts with filename ID {mismatch} in {doc.relpath}")

    if doc_type == "implementation-brief":
        parent = doc.frontmatter.get("parent_plan")
        doc_id = doc.primary_id
        if isinstance(parent, str) and parent and doc_id.startswith("IMPL-"):
            expected = f"IMPL-{parent.split('-')[-1]}-"
            if not doc_id.startswith(expected):
                errors.append(f"Implementation ID {doc_id} does not match parent_plan {parent} in {doc.relpath}")

    if doc_type == "learning" and doc.status == "superseded":
        superseded_by = doc.frontmatter.get("superseded_by")
        reason = doc.frontmatter.get("reason")
        has_replacement = (isinstance(superseded_by, list) and bool(superseded_by)) or (
            isinstance(superseded_by, str) and bool(superseded_by)
        )
        if not has_replacement and not reason:
            errors.append(f"Superseded learning {doc.primary_id or doc.relpath} must include superseded_by or reason in {doc.relpath}")

    if doc_type == "question":
        if doc.status == "answered" and not doc.frontmatter.get("resolution") and not doc.frontmatter.get("resolved_by"):
            errors.append(f"Answered question {doc.primary_id or doc.relpath} must include resolution or resolved_by in {doc.relpath}")
        if doc.status == "superseded":
            superseded_by = doc.frontmatter.get("superseded_by")
            reason = doc.frontmatter.get("reason")
            has_replacement = (isinstance(superseded_by, list) and bool(superseded_by)) or (
                isinstance(superseded_by, str) and bool(superseded_by)
            )
            if not has_replacement and not reason:
                errors.append(f"Superseded question {doc.primary_id or doc.relpath} must include superseded_by or reason in {doc.relpath}")

    return errors


def validate_linked_paths(doc: Doc, root: Path) -> list[str]:
    errors: list[str] = []
    for linked in as_string_list(doc.frontmatter.get("linked_paths")):
        info = linked_path_info(linked, root)
        if info["status"] != "ok":
            errors.append(f"linked_paths entry {linked!r} is {info['status']} in {doc.relpath}")
    return errors


def main() -> int:
    args = parse_args()
    root = docs_root(args.root)
    docs = read_docs(root)

    if args.command == "next":
        if args.family == "todo":
            print(next_todo_id(docs))
            return 0
        print(next_id(args.family, docs, args.plan))
        return 0
    if args.command == "new":
        path = new_doc(args, root, docs)
        print(path)
        return 0
    if args.command == "status":
        selected = [find_doc(docs, args.id)] if args.id else [doc for doc in docs if doc.primary_id]
        for doc in selected:
            if doc:
                print(f"{doc.primary_id or doc.relpath}\t{doc.status or '(none)'}\t{doc.relpath}")
        return 0
    if args.command == "show":
        doc = find_doc(docs, args.id)
        if not doc:
            candidate = resolve_path_input(args.id, root, docs)
            try:
                rel = candidate.resolve().relative_to(root.resolve()).as_posix()
            except ValueError:
                raise SystemExit(f"No document found for {args.id}")
            doc = next((item for item in docs if item.relpath == rel), None)
        if not doc:
            raise SystemExit(f"No document found for {args.id}")
        payload = show_doc(doc, docs, root)
        print_json_or_text(payload, show_doc_text(payload), args.json)
        return 0
    if args.command == "set-status":
        doc = find_doc(docs, args.id)
        if not doc:
            raise SystemExit(f"No document found for {args.id}")
        set_status(doc, args.status)
        print(f"{args.id}\t{args.status}")
        return 0
    if args.command == "todos":
        if args.id and str(args.id).startswith("TODO-"):
            selected_docs = docs
        else:
            selected_docs = [find_doc(docs, args.id)] if args.id else docs
        selected_docs = [doc for doc in selected_docs if doc]
        items = todo_items(selected_docs, include_done=args.all)
        items = filter_todos(items, args)
        print_json_or_text([item.as_dict() for item in items], format_todo_rows(items), args.json)
        return 0
    if args.command == "check-todos":
        return check_todos(docs, args.json, args.strict)
    if args.command == "links":
        refs = link_graph(root, docs)
        if args.target:
            target_doc = find_doc(docs, args.target)
            target_path = resolve_path_input(args.target, root, docs).resolve()
            refs = [
                ref
                for ref in refs
                if ref.source.resolve() == target_path
                or (ref.target is not None and ref.target.resolve() == target_path)
                or (target_doc is not None and ref.source.resolve() == target_doc.path.resolve())
            ]
        print_json_or_text([ref.as_dict() for ref in refs], format_link_rows(refs), args.json)
        return 0
    if args.command == "backlinks":
        refs = link_graph(root, docs)
        target = resolve_path_input(args.target, root, docs).resolve()
        selected = [ref for ref in refs if link_matches_target(ref, target)]
        print_json_or_text([ref.as_dict() for ref in selected], format_link_rows(selected), args.json)
        return 0
    if args.command == "check-links":
        broken = broken_link_refs(link_graph(root, docs))
        print_json_or_text([ref.as_dict() for ref in broken], format_link_rows(broken), args.json)
        return 1 if broken else 0
    if args.command == "orphans":
        refs = link_graph(root, docs)
        orphaned = orphan_docs(root, docs, refs, include_generated=args.include_generated, excludes=args.exclude)
        rows = [{"path": doc.relpath, "id": doc.primary_id, "type": doc.doc_type, "title": doc.title} for doc in orphaned]
        text = "No orphan docs found." if not rows else "\n".join(f"{row['path']}\t{row['id']}\t{row['title']}" for row in rows)
        print_json_or_text(rows, text, args.json)
        return 0
    if args.command == "normalize-links":
        write = bool(args.write)
        refs = [
            ref
            for ref in link_graph(root, docs)
            if ref.status in {"absolute-repo-local", "root-relative"} and ref.target is not None
        ]
        changes = planned_link_rewrites(refs, write)
        text = "No link normalization changes." if not changes else "\n".join(
            f"{change['file']}:{change['line']}\t{change['from']} -> {change['to']}" for change in changes
        )
        print_json_or_text(changes, text, args.json)
        return 0
    if args.command == "move":
        result = perform_move(root, docs, args.old, args.new, bool(args.write), args.allow_historical)
        lines = [
            ("MOVE" if args.write else "DRY-RUN") + f"\t{result['old']} -> {result['new']}",
            "Link changes:",
        ]
        link_changes = result["link_changes"]
        if isinstance(link_changes, list) and link_changes:
            lines.extend(f"- {item['file']}:{item['line']}\t{item['from']} -> {item['to']}" for item in link_changes)
        else:
            lines.append("- none")
        mentions = result["prose_mentions"]
        if isinstance(mentions, list) and mentions:
            lines.append("Prose mentions to review:")
            lines.extend(f"- {item['file']}:{item['line']}\t{item['text']}" for item in mentions)
        print_json_or_text(result, "\n".join(lines), args.json)
        return 0
    if args.command == "update":
        update(root, docs)
        return 0
    if args.command == "check":
        return check(root, docs)
    if args.command == "health":
        issues = health_issues(root, docs, args.stale_days, args.commit_threshold, args.audit_days)
        markdown = generated_view_markdown(root, "health", docs, args)
        if args.write:
            generated_view_path(root, "health").write_text(markdown, encoding="utf-8")
        if args.json:
            print(json.dumps([issue.__dict__ for issue in issues], indent=2))
        else:
            print(health_text(issues))
        return 0
    if args.command == "roadmap":
        rows = roadmap_rows(docs)
        markdown = generated_view_markdown(root, "roadmap", docs, args)
        if args.write:
            generated_view_path(root, "roadmap").write_text(markdown, encoding="utf-8")
        if args.json:
            print(json.dumps(rows, indent=2))
        else:
            print(markdown)
        return 0
    if args.command == "view":
        markdown = write_generated_view(root, args.name, docs, args)
        print(markdown)
        return 0
    raise SystemExit(f"Unknown command: {args.command}")


if __name__ == "__main__":
    raise SystemExit(main())
