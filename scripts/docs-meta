    "diag": re.compile(r"\bDIAG-(\d{4})\b"),
    "spec": re.compile(r"\bSPEC-(\d{4})\b"),
    "plan": re.compile(r"\bPLAN-(\d{4})\b"),
    "impl": re.compile(r"\bIMPL-(\d{4})-(\d{2})\b"),
    "adr": re.compile(r"\bADR-(\d{4})\b"),
    "lrn": re.compile(r"\bLRN-(\d{4})\b"),
    "expl": re.compile(r"\bEXPL-(\d{4})\b"),
    "qst": re.compile(r"\bQST-(\d{4})\b"),
    "conc": re.compile(r"\bCONC-(\d{4})\b"),
}

