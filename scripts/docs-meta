@dataclass
class Doc:
    path: Path
    relpath: str
    frontmatter: dict[str, object]
    content: str
    ids: list[str] = field(default_factory=list)

    @property
    def primary_id(self) -> str:
        value = self.frontmatter.get("id")
        if isinstance(value, str) and value:
            return value
        return self.ids[0] if self.ids else ""

    @property
    def doc_type(self) -> str:
        value = self.frontmatter.get("type")
        if isinstance(value, str) and value:
            return value
        doc_id = self.primary_id
        prefix = doc_id.split("-", 1)[0] if doc_id else ""
        return TYPE_BY_PREFIX.get(prefix, "")

    @property
    def status(self) -> str:
        value = self.frontmatter.get("status")
        return value if isinstance(value, str) else ""

    @property
    def title(self) -> str:
        value = self.frontmatter.get("title")
        if isinstance(value, str) and value:
            return value
        match = re.search(r"^#\s+(.+)$", self.content, re.MULTILINE)
        if match:
            title = match.group(1).strip()
            return re.sub(r"^(IDEA|RSCH|EVAL|DIAG|SPEC|PLAN|IMPL|ADR|LRN|EXPL|QST|CONC)-\d{4}(?:-\d{2})?\s*-\s*", "", title)
        return self.path.stem


@dataclass
class HealthIssue:
    severity: str
    code: str
    doc: str
    message: str
    detail: str = ""


@dataclass
class LinkRef:
    source: Path
    source_rel: str
    line: int
    raw: str
    href: str
    label: str
    kind: str
    href_start: int
    href_end: int
    target: Path | None
    target_rel: str
    status: str
    fragment: str = ""
    detail: str = ""

    def as_dict(self) -> dict[str, object]:
        return {
            "source": self.source_rel,
            "line": self.line,
            "kind": self.kind,
            "label": self.label,
            "href": self.href,
            "target": self.target_rel,
            "status": self.status,
            "fragment": self.fragment,
            "detail": self.detail,
        }


@dataclass
class TodoItem:
    state: str
    line: int
    task: str
    source: str
    path: str
    todo_id: str = ""
    status: str = ""
    owner: str = ""
    agent: str = ""
    skill: str = ""
    plan: str = ""
    brief: str = ""
    metadata: dict[str, str] = field(default_factory=dict)
    structured: bool = False
    raw: str = ""

    def as_dict(self) -> dict[str, object]:
        return {
            "id": self.todo_id,
            "status": self.status,
            "state": self.state,
            "owner": self.owner,
            "agent": self.agent,
            "skill": self.skill,
            "plan": self.plan,
            "brief": self.brief,
            "task": self.task,
            "source": self.source,
            "path": self.path,
            "line": self.line,
            "structured": self.structured,
            "metadata": self.metadata,
            "raw": self.raw,
        }


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Scan and update docs metadata.")
    parser.add_argument("--root", default="docs", help="Docs root to scan. Default: docs")

    sub = parser.add_subparsers(dest="command", required=True)

    next_cmd = sub.add_parser("next", help="Print next ID for a doc family.")
    next_cmd.add_argument("family", choices=["idea", "rsch", "eval", "diag", "spec", "plan", "impl", "adr", "lrn", "expl", "qst", "conc", "todo"])
    next_cmd.add_argument("--plan", help="Required for impl IDs, e.g. PLAN-0034")

    new_cmd = sub.add_parser(
        "new",
        help="Create a new idea, research survey, evaluation, diagnostic, spec, plan, impl doc, ADR, learning, explainer, question, or concept.",
    )
    new_cmd.add_argument(
        "family",
        choices=[
            "idea",
            "research",
            "rsch",
            "eval",
            "evaluation",
            "diag",
            "diagnostic",
            "spec",
            "plan",
            "impl",
            "adr",
            "learning",
            "lrn",
            "explainer",
            "expl",
            "question",
            "qst",
            "concept",
            "conc",
        ],
    )
    new_cmd.add_argument("title")
    new_cmd.add_argument("--domain", default="product")
    new_cmd.add_argument("--spec-type", default="feature")
    new_cmd.add_argument("--status", default="draft")
    new_cmd.add_argument("--owner", default="")
    new_cmd.add_argument("--source-type", default="conversation")
    new_cmd.add_argument("--source-link", default="")
    new_cmd.add_argument("--plan", help="Parent plan for impl docs, e.g. PLAN-0034")
    new_cmd.add_argument("--spec", action="append", default=[], help="Related SPEC-* ID. Repeatable.")

    status_cmd = sub.add_parser("status", help="Show doc statuses.")
    status_cmd.add_argument("id", nargs="?")

    show_cmd = sub.add_parser("show", help="Show one doc with related docs, linked paths, and local TODOs.")
    show_cmd.add_argument("id", help="Doc ID or repo/docs path.")
    show_cmd.add_argument("--json", action="store_true", help="Print machine-readable JSON.")

    set_status_cmd = sub.add_parser("set-status", help="Update a doc status in frontmatter.")
    set_status_cmd.add_argument("id")
    set_status_cmd.add_argument("status", choices=sorted(COMMON_STATUSES))

    todos_cmd = sub.add_parser("todos", help="List Markdown task checkboxes and structured TODO-* items.")
    todos_cmd.add_argument("id", nargs="?", help="Optional doc ID/path or TODO-* ID.")
    todos_cmd.add_argument("--all", action="store_true", help="Include completed todos.")
    todos_cmd.add_argument("--status", help="Filter structured todos by lifecycle status.")
    todos_cmd.add_argument("--owner", help="Filter structured todos by owner.")
    todos_cmd.add_argument("--agent", help="Filter structured todos by agent/session identifier.")
    todos_cmd.add_argument("--skill", help="Filter structured todos by skill.")
    todos_cmd.add_argument("--plan", help="Filter structured todos by PLAN-* reference.")
    todos_cmd.add_argument("--brief", help="Filter structured todos by IMPL-* reference.")
    todos_cmd.add_argument("--structured-only", action="store_true", help="Only list structured TODO-* items.")
    todos_cmd.add_argument("--json", action="store_true", help="Print machine-readable JSON.")

    sub.add_parser("update", help="Regenerate docs registries and todo dashboard.")
    sub.add_parser("check", help="Validate IDs, statuses, and generated docs.")
    check_todos_cmd = sub.add_parser("check-todos", help="Validate structured TODO-* metadata.")
    check_todos_cmd.add_argument("--json", action="store_true", help="Print machine-readable JSON.")
    check_todos_cmd.add_argument("--strict", action="store_true", help="Warn on optional metadata that improves routing and freshness.")

    health_cmd = sub.add_parser("health", help="Show advisory docs freshness and workflow warnings.")
    health_cmd.add_argument("--stale-days", type=int, default=14, help="Flag selected docs not updated in this many days. Default: 14")
    health_cmd.add_argument("--commit-threshold", type=int, default=10, help="Flag docs reviewed this many commits behind HEAD. Default: 10")
    health_cmd.add_argument("--audit-days", type=int, default=30, help="Flag missing or old repo-health audits after this many days. Default: 30")
    health_cmd.add_argument("--json", action="store_true", help="Print machine-readable JSON.")
    health_cmd.add_argument("--write", action="store_true", help="Write docs/HEALTH.md as a generated advisory view.")

    roadmap_cmd = sub.add_parser("roadmap", help="Show generated plan roadmap ordered by frontmatter sequence.")
    roadmap_cmd.add_argument("--json", action="store_true", help="Print machine-readable JSON.")
    roadmap_cmd.add_argument("--write", action="store_true", help="Write docs/ROADMAP-VIEW.md as a generated plan-order view.")

    view_cmd = sub.add_parser("view", help="Print and refresh a generated Markdown view.")
    view_cmd.add_argument("name", choices=["ideas", "specs", "learnings", "explainers", "questions", "concepts", "registry", "todos", "areas", "audits", "roadmap", "health"])
    view_cmd.add_argument("--stale-days", type=int, default=14, help="Health view stale-days threshold. Default: 14")
    view_cmd.add_argument("--commit-threshold", type=int, default=10, help="Health view commit threshold. Default: 10")
    view_cmd.add_argument("--audit-days", type=int, default=30, help="Health view audit threshold. Default: 30")

    links_cmd = sub.add_parser("links", help="List repo-local and external links found in Markdown docs.")
    links_cmd.add_argument("target", nargs="?", help="Optional source path/ID or target path/ID filter.")
    links_cmd.add_argument("--json", action="store_true", help="Print machine-readable JSON.")

    backlinks_cmd = sub.add_parser("backlinks", help="List docs that link to a path or ID.")
    backlinks_cmd.add_argument("target", help="Target path or stable ID.")
    backlinks_cmd.add_argument("--json", action="store_true", help="Print machine-readable JSON.")

    check_links_cmd = sub.add_parser("check-links", help="Report broken repo-local links.")
    check_links_cmd.add_argument("--json", action="store_true", help="Print machine-readable JSON.")

    orphans_cmd = sub.add_parser("orphans", help="Report Markdown docs with no inbound links.")
    orphans_cmd.add_argument("--json", action="store_true", help="Print machine-readable JSON.")
    orphans_cmd.add_argument("--include-generated", action="store_true", help="Include generated views in orphan output.")
    orphans_cmd.add_argument("--exclude", action="append", default=[], help="Glob-style docs-root path to ignore. Repeatable.")

    normalize_cmd = sub.add_parser("normalize-links", help="Normalize repo-local Markdown links.")
    normalize_cmd.add_argument("--style", choices=["relative"], default="relative")
    normalize_cmd.add_argument("--dry-run", action="store_true", help="Preview changes without writing. This is the default unless --write is passed.")
    normalize_cmd.add_argument("--write", action="store_true", help="Rewrite files.")
    normalize_cmd.add_argument("--json", action="store_true", help="Print machine-readable JSON.")

    move_cmd = sub.add_parser("move", help="Move a doc and rewrite Markdown backlinks.")
    move_cmd.add_argument("old")
    move_cmd.add_argument("new")
    move_cmd.add_argument("--dry-run", action="store_true", help="Preview changes without writing. This is the default unless --write is passed.")
    move_cmd.add_argument("--write", action="store_true", help="Move the file and rewrite backlinks.")
    move_cmd.add_argument("--allow-historical", action="store_true", help="Allow moving legacy plan/spec paths.")
    move_cmd.add_argument("--json", action="store_true", help="Print machine-readable JSON.")

    return parser.parse_args()


def docs_root(value: str) -> Path:
    root = Path(value)
    if not root.exists() and Path.cwd().name == "docs":
        root = Path.cwd()
    return root


def read_docs(root: Path) -> list[Doc]:
    docs: list[Doc] = []
    if not root.exists():
        return docs
    for path in sorted(root.rglob("*.md")):
        if any(part in {".git", "node_modules", ".generated"} for part in path.parts):
            continue
        text = path.read_text(encoding="utf-8")
        frontmatter, content = parse_frontmatter(text)
        frontmatter_id = frontmatter.get("id")
        ids = find_ids(path.name)
        if isinstance(frontmatter_id, str):
            ids.extend(find_ids(frontmatter_id))
        ids = sorted(set(ids))
        docs.append(Doc(path=path, relpath=path.relative_to(root).as_posix(), frontmatter=frontmatter, content=content, ids=ids))
    return docs


def repo_root_for(root: Path) -> Path:
    return root.resolve().parent


def relative_to_root(path: Path, root: Path) -> str:
    try:
        return path.resolve().relative_to(root.resolve()).as_posix()
    except ValueError:
        try:
            return path.resolve().relative_to(repo_root_for(root)).as_posix()
        except ValueError:
            return path.as_posix()


def line_number(text: str, offset: int) -> int:
    return text.count("\n", 0, offset) + 1


def split_href(href: str) -> tuple[str, str, str]:
    fragment = ""
    path_and_query = href
    if "#" in path_and_query:
        path_and_query, fragment = path_and_query.split("#", 1)
    query = ""
    path_part = path_and_query
    if "?" in path_part:
        path_part, query = path_part.split("?", 1)
    suffix = ""
    if query:
        suffix += f"?{query}"
    if fragment:
        suffix += f"#{fragment}"
    return path_part, suffix, fragment


def is_external_href(href: str) -> bool:
    return bool(re.match(r"^[A-Za-z][A-Za-z0-9+.-]*:", href)) or href.startswith("//")


def is_path_like_autolink(href: str) -> bool:
    return "/" in href or href.endswith(".md") or href.startswith((".", "#"))


def resolve_path_input(value: str, root: Path, docs: list[Doc] | None = None) -> Path:
    if docs:
        doc = find_doc(docs, value)
        if doc:
            return doc.path
    path = Path(value)
    if path.is_absolute():
        return path
    parts = path.parts
    if parts and parts[0] == root.name:
        return root.parent / path
    return root / path


def resolve_href(href: str, source: Path, root: Path) -> tuple[Path | None, str, str, str]:
    if not href:
        return None, "", "empty", ""
    if is_external_href(href):
        return None, "", "external", ""
    if href.startswith("#"):
        return source, relative_to_root(source, root), "ok", href[1:]

    path_part, _, fragment = split_href(href)
    if not path_part:
        return source, relative_to_root(source, root), "ok", fragment

    decoded = unquote(path_part)
    candidate: Path
    status = "ok"
    root_resolved = root.resolve()
    repo_root = repo_root_for(root)

    if decoded.startswith("/"):
        stripped = decoded.lstrip("/")
        if stripped.startswith(f"{root.name}/"):
            candidate = repo_root / stripped
        else:
            candidate = root / stripped
        status = "root-relative"
    else:
        path = Path(decoded)
        if path.is_absolute():
            candidate = path
            try:
                candidate.resolve().relative_to(repo_root)
                status = "absolute-repo-local"
            except ValueError:
                return candidate, candidate.as_posix(), "outside-repo", fragment
        else:
            candidate = source.parent / path

    candidate = candidate.resolve()
    if candidate.is_dir():
        for index_name in ("README.md", "index.md"):
            index = candidate / index_name
            if index.exists():
                candidate = index.resolve()
                break
        else:
            return candidate, relative_to_root(candidate, root), "directory-no-index", fragment
    if not candidate.exists():
        return candidate, relative_to_root(candidate, root), "missing", fragment
    try:
        candidate.relative_to(root_resolved)
    except ValueError:
        try:
            candidate.relative_to(repo_root)
        except ValueError:
            return candidate, candidate.as_posix(), "outside-repo", fragment
    return candidate, relative_to_root(candidate, root), status, fragment


MD_LINK_RE = re.compile(r"(!?)\[([^\]\n]*)\]\(([^)\s]+)([^)]*)\)")
WIKI_LINK_RE = re.compile(r"(!?)\[\[([^\]|\n]+)(?:\|([^\]\n]+))?\]\]")
AUTOLINK_RE = re.compile(r"<([^<>\s]+)>")


def markdown_ignored_ranges(text: str) -> list[tuple[int, int]]:
    ranges: list[tuple[int, int]] = []
    in_fence = False
    fence_start = 0
    offset = 0
    for line in text.splitlines(keepends=True):
        stripped = line.lstrip()
        if stripped.startswith(("```", "~~~")):
            if in_fence:
                ranges.append((fence_start, offset + len(line)))
                in_fence = False
            else:
                fence_start = offset
                in_fence = True
        if not in_fence:
            for match in re.finditer(r"`[^`\n]+`", line):
                ranges.append((offset + match.start(), offset + match.end()))
        offset += len(line)
    if in_fence:
        ranges.append((fence_start, len(text)))
    return ranges


def in_ignored_markdown_range(offset: int, ranges: list[tuple[int, int]]) -> bool:
    return any(start <= offset < end for start, end in ranges)


def link_refs_for_doc(doc: Doc, root: Path) -> list[LinkRef]:
    refs: list[LinkRef] = []
    text = doc.path.read_text(encoding="utf-8")
    ignored_ranges = markdown_ignored_ranges(text)

    for match in MD_LINK_RE.finditer(text):
        if in_ignored_markdown_range(match.start(), ignored_ranges):
            continue
        href = match.group(3)
        target, target_rel, status, fragment = resolve_href(href, doc.path, root)
        refs.append(
            LinkRef(
                source=doc.path,
                source_rel=doc.relpath,
                line=line_number(text, match.start()),
                raw=match.group(0),
                href=href,
                label=match.group(2),
                kind="markdown-image" if match.group(1) else "markdown-link",
                href_start=match.start(3),
                href_end=match.end(3),
                target=target,
                target_rel=target_rel,
                status=status,
                fragment=fragment,
            )
        )

    for match in WIKI_LINK_RE.finditer(text):
        if in_ignored_markdown_range(match.start(), ignored_ranges):
            continue
        href = match.group(2)
        wiki_path = href.split("#", 1)[0]
        target, target_rel, status, fragment = resolve_href(wiki_path, doc.path, root)
        refs.append(
            LinkRef(
                source=doc.path,
                source_rel=doc.relpath,
                line=line_number(text, match.start()),
                raw=match.group(0),
                href=href,
                label=match.group(3) or href,
                kind="wiki-image" if match.group(1) else "wiki-link",
                href_start=match.start(2),
                href_end=match.end(2),
                target=target,
                target_rel=target_rel,
                status=status if status != "external" else "unsupported-wiki-link",
                fragment=fragment,
                detail="Wikilinks are parsed for visibility but are not the canonical link format.",
            )
        )

    for match in AUTOLINK_RE.finditer(text):
        if in_ignored_markdown_range(match.start(), ignored_ranges):
            continue
        href = match.group(1)
        if href.startswith(("http://", "https://", "mailto:")):
            continue
        if not is_path_like_autolink(href):
            continue
        target, target_rel, status, fragment = resolve_href(href, doc.path, root)
        refs.append(
            LinkRef(
                source=doc.path,
                source_rel=doc.relpath,
                line=line_number(text, match.start()),
                raw=match.group(0),
                href=href,
                label=href,
                kind="autolink",
                href_start=match.start(1),
                href_end=match.end(1),
                target=target,
                target_rel=target_rel,
                status=status,
                fragment=fragment,
            )
        )

    return sorted(refs, key=lambda ref: (ref.source_rel, ref.line, ref.href_start))


def link_graph(root: Path, docs: list[Doc]) -> list[LinkRef]:
    refs: list[LinkRef] = []
    for doc in docs:
        refs.extend(link_refs_for_doc(doc, root))
    return refs


def is_generated_doc(doc: Doc) -> bool:
    return doc.doc_type == "generated-view" or doc.path.name in {
        "IDEAS.md",
        "CONCEPTS.md",
        "SPECS.md",
        "DOCS-REGISTRY.md",
        "TODOS.md",
        "AREAS.md",
        "AUDITS.md",
        "ROADMAP-VIEW.md",
        "HEALTH.md",
    }


def link_matches_target(ref: LinkRef, target: Path) -> bool:
    return ref.target is not None and ref.target.resolve() == target.resolve()


def markdown_link_refs(refs: list[LinkRef]) -> list[LinkRef]:
    return [ref for ref in refs if ref.kind in {"markdown-link", "markdown-image", "autolink"} and ref.target is not None]


def relative_href(source: Path, target: Path, suffix: str = "") -> str:
    rel = os.path.relpath(target.resolve(), start=source.resolve().parent)
    return quote(Path(rel).as_posix(), safe="/") + suffix


def format_link_rows(refs: list[LinkRef]) -> str:
    if not refs:
        return "No links found."
    return "\n".join(
        f"{ref.status}\t{ref.kind}\t{ref.source_rel}:{ref.line}\t{ref.href}\t{ref.target_rel}"
        for ref in refs
    )


def broken_link_refs(refs: list[LinkRef]) -> list[LinkRef]:
    broken_statuses = {"missing", "directory-no-index", "outside-repo", "empty", "unsupported-wiki-link"}
    return [ref for ref in refs if ref.status in broken_statuses]


def orphan_docs(root: Path, docs: list[Doc], refs: list[LinkRef], include_generated: bool = False, excludes: list[str] | None = None) -> list[Doc]:
    inbound = {ref.target.resolve() for ref in refs if ref.target is not None and ref.status in {"ok", "root-relative", "absolute-repo-local"}}
    result: list[Doc] = []
    excludes = excludes or []
    for doc in docs:
        if not include_generated and is_generated_doc(doc):
            continue
        if doc.frontmatter.get("docs_meta_ignore_orphan") or doc.frontmatter.get("orphan_ok"):
            continue
        if any(fnmatch.fnmatch(doc.relpath, pattern) for pattern in excludes):
            continue
        if doc.path.name == "README.md":
            continue
        if doc.path.resolve() not in inbound:
            result.append(doc)
    return sorted(result, key=lambda doc: doc.relpath)


def print_json_or_text(payload: object, text: str, use_json: bool) -> None:
    if use_json:
        print(json.dumps(payload, indent=2))
    else:
        print(text)


def rewrite_markdown_hrefs(path: Path, replacements: list[tuple[int, int, str]], write: bool) -> str:
    text = path.read_text(encoding="utf-8")
    for start, end, href in sorted(replacements, reverse=True):
        text = text[:start] + href + text[end:]
    if write:
        path.write_text(text, encoding="utf-8")
    return text


def planned_link_rewrites(refs: list[LinkRef], write: bool = False) -> list[dict[str, object]]:
    by_file: dict[Path, list[tuple[int, int, str, LinkRef]]] = {}
    for ref in refs:
        _, suffix, _ = split_href(ref.href)
        if not ref.target or ref.kind not in {"markdown-link", "markdown-image", "autolink"}:
            continue
        new_href = relative_href(ref.source, ref.target, suffix)
        if new_href == ref.href:
            continue
        by_file.setdefault(ref.source, []).append((ref.href_start, ref.href_end, new_href, ref))

    changes: list[dict[str, object]] = []
    for path, replacements in sorted(by_file.items(), key=lambda item: item[0].as_posix()):
        rewrite_markdown_hrefs(path, [(start, end, href) for start, end, href, _ in replacements], write)
        for _, _, href, ref in replacements:
            changes.append(
                {
                    "file": ref.source_rel,
                    "line": ref.line,
                    "from": ref.href,
                    "to": href,
                    "target": ref.target_rel,
                }
            )
    return changes


def prose_mentions(root: Path, old_path: Path, refs: list[LinkRef]) -> list[dict[str, object]]:
    old_rel = relative_to_root(old_path, root)
    link_spans = {(ref.source.resolve(), ref.line, ref.href) for ref in refs}
    mentions: list[dict[str, object]] = []
    needles = {old_rel, old_path.name}
    for path in sorted(root.rglob("*.md")):
        text = path.read_text(encoding="utf-8")
        rel = relative_to_root(path, root)
        for idx, line in enumerate(text.splitlines(), start=1):
            if any(needle and needle in line for needle in needles):
                if any(item[0] == path.resolve() and item[1] == idx for item in link_spans):
                    continue
                mentions.append({"file": rel, "line": idx, "text": line.strip()})
    return mentions


def is_historical_move(path: Path, root: Path) -> bool:
    rel = relative_to_root(path, root)
    name = path.name
    return bool(re.match(r"plan-\d", name)) or bool(re.match(r"impl-plan-", name)) or rel.startswith("plans/plan-")


def perform_move(root: Path, docs: list[Doc], old_value: str, new_value: str, write: bool, allow_historical: bool) -> dict[str, object]:
    old_path = resolve_path_input(old_value, root, docs).resolve()
    new_path = resolve_path_input(new_value, root, docs).resolve()
    if not old_path.exists():
        raise SystemExit(f"Move source does not exist: {old_value}")
    if new_path.exists():
        raise SystemExit(f"Move destination already exists: {new_value}")
    try:
        old_path.relative_to(root.resolve())
        new_path.relative_to(root.resolve())
    except ValueError:
        raise SystemExit("docs-meta move only supports paths inside the docs root")
    if is_historical_move(old_path, root) and not allow_historical:
        raise SystemExit("Refusing to move historical plan/brief path without --allow-historical")

    refs = link_graph(root, docs)
    replacements_by_file: dict[Path, list[tuple[int, int, str]]] = {}
    changes: list[dict[str, object]] = []
    for ref in markdown_link_refs(refs):
        if ref.status not in {"ok", "root-relative", "absolute-repo-local"}:
            continue
        _, suffix, _ = split_href(ref.href)
        source_after_move = new_path if ref.source.resolve() == old_path else ref.source
        target_after_move = new_path if ref.target and ref.target.resolve() == old_path else ref.target
        if ref.source.resolve() != old_path and (not ref.target or ref.target.resolve() != old_path):
            continue
        if not target_after_move:
            continue
        new_href = relative_href(source_after_move, target_after_move, suffix)
        if new_href == ref.href:
            continue
        replacements_by_file.setdefault(ref.source, []).append((ref.href_start, ref.href_end, new_href))
        changes.append({"file": ref.source_rel, "line": ref.line, "from": ref.href, "to": new_href})

    mentions = prose_mentions(root, old_path, refs)
    if write:
        for path, replacements in replacements_by_file.items():
            rewrite_markdown_hrefs(path, replacements, True)
        new_path.parent.mkdir(parents=True, exist_ok=True)
        shutil.move(str(old_path), str(new_path))

    return {
        "old": relative_to_root(old_path, root),
        "new": relative_to_root(new_path, root),
        "write": write,
        "link_changes": changes,
        "prose_mentions": mentions,
    }


def parse_frontmatter(text: str) -> tuple[dict[str, object], str]:
    if not text.startswith("---\n"):
        return {}, text
    end = text.find("\n---", 4)
    if end == -1:
        return {}, text
    raw = text[4:end].splitlines()
    content = text[end + 4 :].lstrip("\n")
    data: dict[str, object] = {}
    current_key = ""
    for line in raw:
        if not line.strip():
            continue
        if line.startswith("  - ") and current_key:
            value = str(line[4:].strip()).strip('"')
            if not isinstance(data.get(current_key), list):
                data[current_key] = []
            data[current_key].append(value)
            continue
        if line.startswith("  ") and current_key:
            nested = line.strip()
            if ":" in nested:
                child_key, child_value = nested.split(":", 1)
                if not isinstance(data.get(current_key), dict):
                    data[current_key] = {}
                target = data[current_key]
                if isinstance(target, dict):
                    target[child_key.strip()] = parse_scalar(child_value.strip())
            continue
        if ":" not in line:
            continue
        key, value = line.split(":", 1)
        key = key.strip()
        value = value.strip()
        current_key = key
        data[key] = parse_scalar(value)
    return data, content


def parse_scalar(value: str) -> object:
    if value == "[]":
        return []
    if value.startswith("[") and value.endswith("]"):
        inner = value[1:-1].strip()
        if not inner:
            return []
        return [item.strip().strip('"').strip("'") for item in inner.split(",") if item.strip()]
    if value == "":
        return ""
    return value.strip('"')


def find_ids(text: str) -> list[str]:
    ids: list[str] = []
    for pattern in ID_PATTERNS.values():
        for match in pattern.finditer(text):
            ids.append(match.group(0))
    return ids


def slugify(title: str) -> str:
    slug = title.lower()
    slug = re.sub(r"[^a-z0-9]+", "-", slug)
    return slug.strip("-") or "untitled"


def now_string() -> str:
    now = dt.datetime.now().astimezone()
    zone = now.tzname() or "local"
    offset = now.strftime("%z")
    return now.strftime(f"%Y-%m-%d %H:%M:%S {zone} {offset}")


def git_head() -> str:
    try:
        result = subprocess.run(["git", "rev-parse", "HEAD"], check=True, capture_output=True, text=True)
        return result.stdout.strip()
    except Exception:
        return ""


def git_commit_count_since(commit: str) -> int | None:
    if not commit:
        return None
    try:
        result = subprocess.run(["git", "rev-list", "--count", f"{commit}..HEAD"], check=True, capture_output=True, text=True)
        return int(result.stdout.strip())
    except Exception:
        return None


def next_id(family: str, docs: list[Doc], plan: str | None = None) -> str:
    if family == "impl":
        if not plan or not re.fullmatch(r"PLAN-\d{4}", plan):
            raise SystemExit("--plan PLAN-#### is required for impl IDs")
        plan_num = plan.split("-")[1]
        max_suffix = 0
        for doc in docs:
            for doc_id in doc.ids:
                match = re.fullmatch(rf"IMPL-{plan_num}-(\d{{2}})", doc_id)
                if match:
                    max_suffix = max(max_suffix, int(match.group(1)))
        return f"IMPL-{plan_num}-{max_suffix + 1:02d}"

    pattern = ID_PATTERNS[family]
    max_num = 0
    for doc in docs:
        for doc_id in doc.ids:
            match = pattern.fullmatch(doc_id)
            if match:
                max_num = max(max_num, int(match.group(1)))
    return f"{family.upper()}-{max_num + 1:04d}"


def next_todo_id(docs: list[Doc]) -> str:
    max_num = 0
    for item in todo_items(docs, include_done=True):
        if not item.todo_id:
            continue
        match = TODO_ID_RE.fullmatch(item.todo_id)
        if match:
            max_num = max(max_num, int(match.group(1)))
    return f"TODO-{max_num + 1:04d}"


def find_doc(docs: list[Doc], doc_id: str) -> Doc | None:
    for doc in docs:
        if doc.primary_id == doc_id or doc_id in doc.ids:
            return doc
    return None


def as_string_list(value: object) -> list[str]:
    if isinstance(value, list):
        return [str(item).strip() for item in value if str(item).strip()]
    if isinstance(value, str) and value.strip():
        return [value.strip()]
    return []


def linked_path_info(raw: str, root: Path) -> dict[str, str]:
    repo_root = repo_root_for(root)
    candidate = Path(raw)
    resolved = candidate.resolve() if candidate.is_absolute() else (repo_root / candidate).resolve()
    try:
        rel_repo = resolved.relative_to(repo_root.resolve()).as_posix()
    except ValueError:
        return {"input": raw, "path": resolved.as_posix(), "status": "outside-repo"}
    return {"input": raw, "path": rel_repo, "status": "ok" if resolved.exists() else "missing"}


def relation_summary(doc: Doc, docs: list[Doc]) -> list[dict[str, str]]:
    rows: list[dict[str, str]] = []
    keys = ["parent_plan"] + sorted(
        key
        for key in doc.frontmatter
        if key.startswith("related_") or key in {"supersedes", "superseded_by", "promoted_to", "resolved_by"}
    )
    seen: set[tuple[str, str]] = set()
    for key in keys:
        for value in as_string_list(doc.frontmatter.get(key)):
            pair = (key, value)
            if pair in seen:
                continue
            seen.add(pair)
            target = find_doc(docs, value)
            rows.append(
                {
                    "field": key,
                    "id": value,
                    "path": target.relpath if target else "",
                    "status": target.status if target else "",
                    "title": target.title if target else "",
                }
            )
    return rows


def show_doc(doc: Doc, docs: list[Doc], root: Path) -> dict[str, object]:
    return {
        "id": doc.primary_id,
        "type": doc.doc_type,
        "title": doc.title,
        "status": doc.status,
        "path": doc.relpath,
        "relations": relation_summary(doc, docs),
        "linked_paths": [linked_path_info(path, root) for path in as_string_list(doc.frontmatter.get("linked_paths"))],
        "todos": [item.as_dict() for item in todo_items_for_doc(doc, include_done=True)],
    }


def show_doc_text(payload: dict[str, object]) -> str:
    lines = [
        f"ID:\t{payload.get('id', '')}",
        f"Type:\t{payload.get('type', '')}",
        f"Title:\t{payload.get('title', '')}",
        f"Status:\t{payload.get('status', '')}",
        f"Path:\t{payload.get('path', '')}",
        "",
        "Relations:",
    ]
    relations = payload.get("relations", [])
    if isinstance(relations, list) and relations:
        for item in relations:
            if not isinstance(item, dict):
                continue
            suffix = f" -> {item.get('path', '')}" if item.get("path") else ""
            title = f" ({item.get('title', '')})" if item.get("title") else ""
            lines.append(f"- {item.get('field', '')}: {item.get('id', '')}{suffix}{title}")
    else:
        lines.append("- none")
    lines.extend(["", "Linked Paths:"])
    linked_paths = payload.get("linked_paths", [])
    if isinstance(linked_paths, list) and linked_paths:
        for item in linked_paths:
            if not isinstance(item, dict):
                continue
            lines.append(f"- {item.get('input', '')}: {item.get('status', '')} -> {item.get('path', '')}")
    else:
        lines.append("- none")
    lines.extend(["", "Todos:"])
    todos = payload.get("todos", [])
    if isinstance(todos, list) and todos:
        for item in todos:
            if not isinstance(item, dict):
                continue
            todo_id = item.get("id", "")
            prefix = f"{todo_id} " if todo_id else ""
            status = item.get("status", item.get("state", ""))
            lines.append(f"- {prefix}[{status}] {item.get('task', '')}")
    else:
        lines.append("- none")
    return "\n".join(lines)


def new_doc(args: argparse.Namespace, root: Path, docs: list[Doc]) -> Path:
    title = args.title
    slug = slugify(title)
    timestamp = now_string()
    commit = git_head()

    if args.family == "idea":
        doc_id = next_id("idea", docs)
        path = root / args.domain / "ideas" / f"{doc_id}-{slug}.md"
        body = idea_doc(doc_id, title, args, timestamp, commit)
    elif args.family in {"research", "rsch"}:
        doc_id = next_id("rsch", docs)
        path = root / "research" / f"{doc_id}-{slug}.md"
        body = research_survey_doc(doc_id, title, args, timestamp, commit)
    elif args.family in {"eval", "evaluation"}:
        doc_id = next_id("eval", docs)
        path = root / "repo-health" / "evaluations" / f"{doc_id}-{slug}.md"
        body = evaluation_doc(doc_id, title, args, timestamp, commit)
    elif args.family in {"diag", "diagnostic"}:
        doc_id = next_id("diag", docs)
        path = root / "repo-health" / "debugging" / "diagnostics" / f"{doc_id}-{slug}.md"
        body = diagnostic_doc(doc_id, title, args, timestamp, commit)
    elif args.family in {"concept", "conc"}:
        doc_id = next_id("conc", docs)
        path = root / args.domain / "concepts" / f"{doc_id}-{slug}.md"
        body = concept_doc(doc_id, title, args, timestamp, commit)
    elif args.family == "spec":
        doc_id = next_id("spec", docs)
        path = root / args.domain / "specs" / f"{doc_id}-{slug}.md"
        body = spec_doc(doc_id, title, args, timestamp, commit)
    elif args.family == "plan":
        doc_id = next_id("plan", docs)
        path = root / args.domain / "plans" / f"{doc_id}-{slug}" / f"{doc_id}-{slug}.md"
        body = plan_doc(doc_id, title, args, timestamp, commit)
    elif args.family == "impl":
        if not args.plan:
            raise SystemExit("--plan PLAN-#### is required for impl docs")
        doc_id = next_id("impl", docs, args.plan)
        parent = find_doc(docs, args.plan)
        base = parent.path.parent if parent else root / args.domain / "plans" / args.plan
        path = base / f"{doc_id}-{slug}.md"
        body = impl_doc(doc_id, title, args, timestamp, commit)
    elif args.family == "adr":
        doc_id = next_id("adr", docs)
        path = root / "decisions" / "adr" / f"{doc_id}-{slug}.md"
        body = adr_doc(doc_id, title, args, timestamp, commit)
    elif args.family in {"learning", "lrn"}:
        doc_id = next_id("lrn", docs)
        path = root / "decisions" / "learnings" / f"{doc_id}-{slug}.md"
        body = learning_doc(doc_id, title, args, timestamp, commit)
    elif args.family in {"explainer", "expl"}:
        doc_id = next_id("expl", docs)
        path = root / "orientation" / "explainers" / f"{doc_id}-{slug}.md"
        body = explainer_doc(doc_id, title, args, timestamp, commit)
    else:
        doc_id = next_id("qst", docs)
        path = root / "decisions" / "questions" / f"{doc_id}-{slug}.md"
        body = question_doc(doc_id, title, args, timestamp, commit)

    if path.exists():
        raise SystemExit(f"Refusing to overwrite existing file: {path}")
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(body, encoding="utf-8")
    return path


def status_for_new(args: argparse.Namespace, doc_type: str) -> str:
    status = args.status
    if doc_type == "adr" and status == "draft":
        status = "proposed"
    if doc_type == "idea" and status == "draft":
        status = "captured"
    if doc_type == "learning" and status == "draft":
        status = "active"
    if doc_type == "question" and status == "draft":
        status = "open"
    if doc_type == "diagnostic-record" and status == "draft":
        status = "investigating"
    allowed = STATUS_BY_TYPE.get(doc_type, COMMON_STATUSES)
    if status not in allowed:
        raise SystemExit(f"Status {status!r} is not valid for {doc_type}; choose one of: {', '.join(sorted(allowed))}")
    return status


def yaml_list(values: list[str]) -> str:
    if not values:
        return "[]"
    return "\n" + "\n".join(f"  - {value}" for value in values)


def repo_state_yaml(commit: str) -> str:
    return f"""repo_state:
  based_on_commit: {commit}
  last_reviewed_commit: {commit}"""


def idea_doc(doc_id: str, title: str, args: argparse.Namespace, timestamp: str, commit: str) -> str:
    status = status_for_new(args, "idea")
    return f"""---
type: idea
id: {doc_id}
title: {title}
domain: {args.domain}
status: {status}
created_at: "{timestamp}"
updated_at: "{timestamp}"
owner: {args.owner}
source:
  type: {args.source_type}
  link: {args.source_link}
  notes:
areas: []
related_specs: []
related_research: []
related_issues: []
related_prs: []
related_sessions: []
linked_paths: []
promoted_to: []
repo_state:
  based_on_commit:
  last_reviewed_commit:
---

# {doc_id} - {title}

## Raw Thought

## Why It Might Matter

## Possible Shape

